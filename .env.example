# ─── Servidor ───────────────────────────────────────────────
PORT=3000
# En producción (Render) pon NODE_ENV=production: activa cookies seguras,
# 'trust proxy' y el almacén de sesión en PostgreSQL.
NODE_ENV=development
# URL pública del sistema. En Render: https://<nombre>.onrender.com
APP_URL=http://localhost:3000
# Secreto para firmar la cookie de sesión del admin (cámbialo)
SESSION_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# ─── Base de datos PostgreSQL ───────────────────────────────
# Local (Docker):  postgres://usuario:password@localhost:5432/reportes_sismo
# Neon (nube):     postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   Si la URL contiene "neon.tech", se usa automáticamente el driver serverless
#   de Neon (conecta por WebSocket/443; útil si tu red bloquea el puerto 5432).
#   Fuerza el driver clásico TCP con DB_DRIVER=pg.
DATABASE_URL=postgres://usuario:password@localhost:5432/reportes_sismo

# ─── Cloudinary (subida de fotos) ───────────────────────────
# Lo encuentras en el dashboard de Cloudinary como "API Environment variable".
# La API_KEY es la parte NUMÉRICA: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# La clave debe tener permiso de subida (create).
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ─── Administrador (moderación) ─────────────────────────────
# Cuenta para iniciar sesión en /admin y moderar (ocultar reportes/comentarios,
# forzar el cierre de un reporte). Se crea/actualiza con `npm run db:setup`.
ADMIN_EMAIL=admin@reportes-sismo.ve
ADMIN_PASSWORD=cambia-esta-contrasena
