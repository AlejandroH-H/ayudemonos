# ─── Servidor ───────────────────────────────────────────────
PORT=3000
# En producción (Render) pon NODE_ENV=production: activa cookies seguras y
# 'trust proxy'. En local déjalo vacío o en "development".
NODE_ENV=development
# URL pública del sistema (se usa en los enlaces de los correos).
# En Render: https://<nombre>.onrender.com
APP_URL=http://localhost:3000
# Secreto para firmar las cookies de sesión del panel (cámbialo)
SESSION_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# ─── Base de datos PostgreSQL ───────────────────────────────
# Local (Docker):  postgres://usuario:password@localhost:5432/reportes_sismo
# Neon (nube):     postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   Si la URL contiene "neon.tech", se usa automáticamente el driver serverless
#   de Neon (conecta por WebSocket/443; útil si tu red bloquea el puerto 5432).
#   Fuerza el driver clásico TCP con DB_DRIVER=pg.
DATABASE_URL=postgres://usuario:password@localhost:5432/reportes_sismo

# ─── Cloudinary (subida de fotos) ───────────────────────────
# Lo encuentras en el dashboard de Cloudinary como "API Environment variable"
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ─── Correo (Nodemailer) ────────────────────────────────────
# Tres modos:
#   json     → no envía nada por red; compone el correo y registra el
#              destinatario en consola. Ideal para ver el enrutamiento por
#              estado o si tu red bloquea los puertos SMTP (587/465).
#   ethereal → cuenta de prueba automática; no envía correos reales pero da una
#              URL de previsualización. Requiere salida SMTP por el puerto 587.
#   smtp     → envío real; configura las variables SMTP_* de abajo.
MAIL_TRANSPORT=ethereal
MAIL_FROM="Sistema de Reportes Sismo <no-reply@reportes-sismo.ve>"

# ── Gmail (MAIL_TRANSPORT=smtp) ──
#   1. Activa la Verificación en 2 pasos en la cuenta Gmail.
#   2. Genera una "Contraseña de aplicación" (16 caracteres) y úsala en SMTP_PASS.
#   3. MAIL_FROM debe usar la MISMA dirección que SMTP_USER (Gmail lo exige).
#   Límite ~500 correos/día en Gmail gratuito.
# Para migrar a Brevo/SendGrid: cambia solo SMTP_HOST, SMTP_USER y SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=contrasena-de-aplicacion-de-16-caracteres
