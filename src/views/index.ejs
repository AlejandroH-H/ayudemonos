<%- include('partials/header', { titulo: 'Reportes Sismo Venezuela' }) %>
<%
  const tipoLabels = {
    medica: 'Médica', rescate: 'Rescate', refugio: 'Refugio', agua: 'Agua',
    alimentos: 'Alimentos', desaparecido: 'Desaparecido', dano_estructural: 'Daño estructural', otro: 'Otro'
  };
  function tarjeta(r){
%>
  <a class="reporte-card" href="/reporte/<%= r.id %>">
    <div class="reporte-card-top">
      <span class="sev-tag sev-tag-<%= r.severidad %>"><%= r.severidad %></span>
      <span class="tipo-pill"><%= tipoLabels[r.tipo_emergencia] || r.tipo_emergencia %></span>
      <% if (r.subsanado) { %><span class="badge badge-resuelto">Subsanado</span><% } %>
    </div>
    <h3 class="reporte-card-title"><%= r.persona_nombre ? r.persona_nombre : (r.estado + (r.municipio ? ' — ' + r.municipio : '')) %></h3>
    <p class="reporte-card-desc"><%= r.descripcion.length > 120 ? r.descripcion.slice(0,120) + '…' : r.descripcion %></p>
    <div class="reporte-card-meta">
      <span class="meta-icono"><%- icono('map-pin', { size: 14 }) %> <%= r.estado %></span>
      <span><%= fmtFecha(r.creado_en) %></span>
    </div>
  </a>
<% } %>

<section class="hero hero-compact">
  <p class="kicker">Sistema comunitario de reportes</p>
  <h1>Reporta, sigue y confirma. Todo a la vista de la comunidad.</h1>
  <p class="lead">
    Publica un reporte de una persona o situación afectada por el sismo. Cualquiera puede
    comentar y confirmar cuando una persona es encontrada o la situación se resuelve.
  </p>
  <div class="cta-row">
    <a class="btn btn-primary btn-lg" href="/reportar">Crear un reporte</a>
  </div>
</section>

<section class="stats">
  <div class="stat-card">
    <span class="stat-num"><%= stats.total %></span>
    <span class="stat-label">Reportes creados</span>
  </div>
  <div class="stat-card stat-activos">
    <span class="stat-num"><%= stats.activos %></span>
    <span class="stat-label">Sin subsanar</span>
  </div>
  <div class="stat-card stat-subsanados">
    <span class="stat-num"><%= stats.subsanados %></span>
    <span class="stat-label">Subsanados</span>
  </div>
  <div class="stat-card">
    <span class="stat-num"><%= stats.personas_afectadas %></span>
    <span class="stat-label">Personas afectadas</span>
  </div>
</section>

<section>
  <h2 class="section-title">Reportes activos <span class="count">(<%= activos.length %>)</span></h2>
  <% if (!activos.length) { %>
    <div class="card center"><p class="muted">No hay reportes activos.</p></div>
  <% } else { %>
    <div class="reporte-grid">
      <% activos.forEach(function(r){ tarjeta(r); }) %>
    </div>
  <% } %>
</section>

<section>
  <h2 class="section-title">Reportes subsanados <span class="count">(<%= subsanados.length %>)</span></h2>
  <% if (!subsanados.length) { %>
    <div class="card center"><p class="muted">Aún no hay reportes subsanados.</p></div>
  <% } else { %>
    <div class="reporte-grid">
      <% subsanados.forEach(function(r){ tarjeta(r); }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
