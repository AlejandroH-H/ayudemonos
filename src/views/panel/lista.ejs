<%- include('../partials/header', { titulo: 'Panel — ' + autoridad.estado }) %>
<%
  const tipoLabels = {
    medica: 'Médica', rescate: 'Rescate', refugio: 'Refugio', agua: 'Agua',
    alimentos: 'Alimentos', desaparecido: 'Desaparecido', dano_estructural: 'Daño estructural', otro: 'Otro'
  };
  const segLabels = { recibido: 'Recibido', en_atencion: 'En atención', resuelto: 'Resuelto' };
  function fecha(d){ return new Date(d).toLocaleString('es-VE'); }
%>

<div class="panel-head">
  <div>
    <h1 class="page-title">Reportes — <%= autoridad.estado %></h1>
    <p class="muted"><%= autoridad.organismo %></p>
  </div>
</div>

<div class="filtros">
  <a href="/panel" class="chip <%= !filtro ? 'chip-active' : '' %>">Todos</a>
  <% seguimientos.forEach(function(s){ %>
    <a href="/panel?seguimiento=<%= s %>" class="chip <%= filtro === s ? 'chip-active' : '' %>"><%= segLabels[s] %></a>
  <% }) %>
</div>

<% if (!reportes.length) { %>
  <div class="card center"><p class="muted">No hay reportes<%= filtro ? ' con ese estado de seguimiento' : '' %>.</p></div>
<% } else { %>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Código</th><th>Tipo</th><th>Severidad</th><th>Personas</th>
          <th>Ubicación</th><th>Fecha</th><th>Seguimiento</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% reportes.forEach(function(r){ %>
          <tr class="sev-row sev-<%= r.severidad %>">
            <td class="mono"><%= r.codigo %></td>
            <td><%= tipoLabels[r.tipo_emergencia] || r.tipo_emergencia %></td>
            <td><span class="sev-tag sev-tag-<%= r.severidad %>"><%= r.severidad %></span></td>
            <td><%= r.personas_afectadas %></td>
            <td><%= [r.municipio, r.direccion].filter(Boolean).join(' — ') || '—' %></td>
            <td class="muted"><%= fecha(r.creado_en) %></td>
            <td><span class="badge badge-<%= r.seguimiento %>"><%= segLabels[r.seguimiento] %></span></td>
            <td><a class="btn btn-sm" href="/panel/reporte/<%= r.id %>">Ver</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
