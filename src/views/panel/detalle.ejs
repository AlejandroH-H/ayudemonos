<%- include('../partials/header', { titulo: 'Reporte ' + reporte.codigo }) %>
<%
  const tipoLabels = {
    medica: 'Emergencia médica', rescate: 'Rescate', refugio: 'Refugio', agua: 'Agua',
    alimentos: 'Alimentos', desaparecido: 'Persona desaparecida', dano_estructural: 'Daño estructural', otro: 'Otro'
  };
  const segLabels = { recibido: 'Recibido', en_atencion: 'En atención', resuelto: 'Resuelto' };
  function fecha(d){ return new Date(d).toLocaleString('es-VE'); }
%>

<p><a href="/panel" class="back-link">← Volver a la lista</a></p>

<div class="detalle-grid">
  <div class="card">
    <div class="detalle-head">
      <h1 class="mono"><%= reporte.codigo %></h1>
      <span class="sev-tag sev-tag-<%= reporte.severidad %>"><%= reporte.severidad %></span>
    </div>

    <dl class="resumen">
      <div><dt>Tipo</dt><dd><%= tipoLabels[reporte.tipo_emergencia] || reporte.tipo_emergencia %></dd></div>
      <div><dt>Estado</dt><dd><%= reporte.estado %></dd></div>
      <div><dt>Municipio</dt><dd><%= reporte.municipio || '—' %></dd></div>
      <div><dt>Dirección</dt><dd><%= reporte.direccion || '—' %></dd></div>
      <div><dt>Personas afectadas</dt><dd><%= reporte.personas_afectadas %></dd></div>
      <div><dt>Fecha</dt><dd><%= fecha(reporte.creado_en) %></dd></div>
      <div><dt>Contacto</dt><dd><%= reporte.contacto_nombre || '—' %></dd></div>
      <div><dt>Teléfono</dt><dd><%= reporte.contacto_telefono || '—' %></dd></div>
    </dl>

    <h3>Descripción</h3>
    <p class="descripcion"><%= reporte.descripcion %></p>

    <% if (reporte.lat && reporte.lng) { %>
      <p><a class="btn btn-ghost btn-sm" target="_blank" rel="noopener"
            href="https://www.openstreetmap.org/?mlat=<%= reporte.lat %>&mlon=<%= reporte.lng %>#map=17/<%= reporte.lat %>/<%= reporte.lng %>">
        Ver ubicación en el mapa
      </a></p>
    <% } %>

    <% if (reporte.foto_url) { %>
      <h3>Foto</h3>
      <a href="<%= reporte.foto_url %>" target="_blank" rel="noopener">
        <img class="evidencia" src="<%= reporte.foto_url %>" alt="Foto del reporte <%= reporte.codigo %>" />
      </a>
    <% } %>
  </div>

  <aside class="card seguimiento-box">
    <h3>Seguimiento</h3>
    <p>Estado actual:
      <span class="badge badge-<%= reporte.seguimiento %>"><%= segLabels[reporte.seguimiento] %></span>
    </p>
    <form action="/panel/reporte/<%= reporte.id %>/seguimiento" method="post" class="form">
      <div class="field">
        <label for="seguimiento">Cambiar a</label>
        <select id="seguimiento" name="seguimiento">
          <% seguimientos.forEach(function(s){ %>
            <option value="<%= s %>" <%= reporte.seguimiento === s ? 'selected' : '' %>><%= segLabels[s] %></option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Actualizar</button>
    </form>
  </aside>
</div>

<%- include('../partials/footer') %>
