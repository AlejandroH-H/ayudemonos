<%- include('../partials/header', { titulo: 'Moderación' }) %>
<%
  function fecha(d){ return new Date(d).toLocaleString('es-VE'); }
%>

<h1 class="page-title">Moderación de reportes</h1>
<p class="muted">Todos los reportes, incluidos los ocultos.</p>

<% if (!reportes.length) { %>
  <div class="card center"><p class="muted">No hay reportes.</p></div>
<% } else { %>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr><th>Código</th><th>Estado</th><th>Persona / tipo</th><th>Estado rep.</th><th>Visible</th><th>Fecha</th><th></th></tr>
      </thead>
      <tbody>
        <% reportes.forEach(function(r){ %>
          <tr>
            <td class="mono"><%= r.codigo %></td>
            <td><%= r.estado %></td>
            <td><%= r.persona_nombre || r.tipo_emergencia %></td>
            <td>
              <% if (r.subsanado) { %><span class="badge badge-resuelto">Subsanado</span>
              <% } else { %><span class="badge badge-recibido">Activo</span><% } %>
            </td>
            <td><%= r.oculto ? '🚫 oculto' : '✓' %></td>
            <td class="muted"><%= fecha(r.creado_en) %></td>
            <td class="acciones">
              <a class="btn btn-sm" href="/admin/reporte/<%= r.id %>">Ver</a>
              <form action="/admin/reporte/<%= r.id %>/oculto" method="post" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="oculto" value="<%= r.oculto ? 'false' : 'true' %>" />
                <button class="btn btn-sm btn-ghost"><%= r.oculto ? 'Mostrar' : 'Ocultar' %></button>
              </form>
              <% if (!r.subsanado) { %>
                <form action="/admin/reporte/<%= r.id %>/subsanar" method="post" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn btn-sm btn-ghost">Subsanar</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
